flowchart TD
    A["get_connected_stream(address)"] --> B{"目标流量类型"}
    B -->|"TCP relay"| C["tcp_pool"]
    B -->|"UDP relay / DNS / shared UDP relay"| D["udp_pool"]
    C --> E{"有可用 raw Yamux session?"}
    D --> F{"有可用 raw Yamux session?"}
    E -->|"否"| G["创建/补充 TCP raw Yamux 外层连接"]
    F -->|"否"| H["创建/补充 UDP raw Yamux 外层连接"]
    E -->|"是"| I["打开 Yamux 子流"]
    F -->|"是"| I
    G --> I
    H --> I
    I --> J["子流内发送 Auth"]
    J --> K{"AuthResponse 成功?"}
    K -->|"否"| Z["返回认证错误"]
    K -->|"是"| L["子流内发送 ConnectRequest"]
    L --> M{"ConnectResponse 成功?"}
    M -->|"否"| Y["返回业务错误"]
    M -->|"是"| N["返回加密 DataPacket 流"]
