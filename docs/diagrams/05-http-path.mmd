flowchart TD
    A["本地 HTTP 客户端连接"] --> B["hyper http1 server"]
    B --> C{"请求方法"}
    C -->|"CONNECT"| D["解析 host:port 默认 443"]
    C -->|"普通 HTTP"| E["从 Host/URI 解析 host:port 默认 80"]
