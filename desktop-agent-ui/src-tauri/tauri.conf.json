{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PPAASS Desktop Agent",
  "version": "0.1.0",
  "identifier": "com.ppaass.agent",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PPAASS Agent",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": true,
        "theme": "Light"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../config/local/agent.toml": "config/local/agent.toml",
      "../../keys/user1.pem": "keys/user1.pem",
      "../../keys/user2.pem": "keys/user2.pem",
      "../../wintun.dll": "wintun.dll"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
